# Copy this file to .env for local development.
# In production, set these as environment variables in the Render dashboard.

FLASK_APP=backend
FLASK_APP_VERSION=0.1.0

# Set to True for local development, False in production.
FLASK_DEBUG=True
FLASK_ENV=development

# Local dev: sqlite:///stockalert.db  (resolves to instance/stockalert.db)
# Production: sqlite:////data/stockalert.db  (Render Persistent Disk mounted at /data)
FLASK_SQLALCHEMY_DATABASE_URI=sqlite:///stockalert.db

# Telegram bot credentials — get from BotFather on Telegram.
FLASK_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
FLASK_TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Background job interval (minutes).
FLASK_LAST_PRICES_FETCH_INTERVAL=15

# CORS origin for the Vue.js frontend.
# Local: http://localhost:5173
# Production: https://your-deployed-frontend-url.com
FLASK_FRONTEND_URL=http://localhost:5173
